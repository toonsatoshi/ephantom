{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "dist"
  },
  "include": ["shared/**/*", "tests/**/*", "scripts/**/*"],
  "exclude": ["node_modules"]
}
